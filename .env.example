# Copy to .env.local in each app folder and fill in.
# Never commit .env files.

# ---------- Backend (apps/api) ----------

# Anthropic API — for the Agent SDK and report-composed sections
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google APIs — base64-encoded service account JSON
# (get with: base64 -w0 service-account.json)
GOOGLE_SERVICE_ACCOUNT_JSON=
METRIC_SHEET_ID=
DRIVE_SESSIONS_FOLDER_ID=
DRIVE_CLIENT_TEMPLATE_FILE_ID=
DRIVE_BRIEF_TEMPLATE_FILE_ID=

# Resend — transactional email
RESEND_API_KEY=

# Team emails that get the "session complete" notification
# Comma-separated. Change here to add/remove recipients (no code change).
NOTIFICATION_EMAILS=biancasmit683@gmail.com

# Admin page gate — bcrypt hash of the password used to access the new-session page
ADMIN_PAGE_PASSWORD_HASH=

# CORS — the frontend origin
APP_FRONTEND_ORIGIN=http://localhost:5173

# Path to the interview flow JSON (relative to api)
FLOW_CONFIG_PATH=../../config/03-INTERVIEW-FLOW.json

# Server port (Vercel sets this automatically in prod)
PORT=3000

# ---------- Frontend (apps/web) ----------

# Where the API lives (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000
